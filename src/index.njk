<script>
(function () {
  fetch('/api/youtube-videos')
    .then(function (r) { return r.json(); })
    .then(function (data) {
      var videos = data.videos || [];
      if (!videos.length) return; // keep the "coming soon" state showing

      var container = document.getElementById('wlt-container');
      var featured = videos[0];
      var rest = videos.slice(1, 4);
      var channelUrl = data.channelUrl || 'https://www.youtube.com/@prisonerlegal';

      var html = '<div class="tv-grid">' +
        '<div class="video-frame"><iframe src="https://www.youtube-nocookie.com/embed/' + featured.id +
        '" title="' + escapeAttr(featured.title) +
        '" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>' +
        '<div class="tv-side"><h3>' + escapeHtml(featured.title) + '</h3>' +
        '<p>New from Writ Large TV.</p>' +
        '<a class="yt-btn" href="' + channelUrl + '" target="_blank" rel="noopener">Subscribe on YouTube →</a></div>' +
        '</div>';

      if (rest.length) {
        html += '<div class="shorts-row">';
        rest.forEach(function (v) {
          html += '<div class="short-frame"><iframe src="https://www.youtube-nocookie.com/embed/' + v.id +
            '" title="' + escapeAttr(v.title) + '" loading="lazy" allowfullscreen></iframe></div>';
        });
        html += '</div>';
      }

      container.innerHTML = html;
    })
    .catch(function () { /* network hiccup — keep showing the empty state */ });

  function escapeHtml(s) {
    var d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }
  function escapeAttr(s) {
    return escapeHtml(s).replace(/"/g, '&quot;');
  }
})();
</script>

